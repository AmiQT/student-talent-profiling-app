# =============================================================================
# Backend Environment
# Copy this file to .env and fill in your own values.
# .env is gitignored — NEVER commit real keys.
# =============================================================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/talent_db

# CORS — comma-separated production URLs (localhost always allowed by default)
ALLOWED_ORIGINS=https://your-dashboard.vercel.app,https://your-app.vercel.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Server
PORT=8000
ENVIRONMENT=development

# =============================================================================
# Supabase
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
# Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# =============================================================================
# AI Provider — default: Gemini
# =============================================================================
AI_PROVIDER=gemini
AI_MODEL_NAME=gemini-2.5-flash
AI_TEMPERATURE=0.7
GEMINI_API_KEY=your-gemini-api-key-here
# Multiple keys for rotation (optional):
# GEMINI_API_KEYS=key1,key2,key3

# --- Ollama (self-hosted, optional) ---
# AI_PROVIDER=ollama
# AI_BASE_URL=http://your-ollama-host:11434
# AI_MODEL_NAME=gemma3:4b

# =============================================================================
# Payment (ToyyibPay)
# =============================================================================
TOYYIBPAY_USER_SECRET_KEY=your-secret-key
TOYYIBPAY_CATEGORY_CODE=your-category-code
