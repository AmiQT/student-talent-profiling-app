# =============================================================================
# Mobile App Environment
# Copy this file to assets/.env and fill in your own values.
# assets/.env is gitignored — NEVER commit real keys.
# =============================================================================

# Supabase (required) — Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Backend URL (required) — your deployed FastAPI backend
BACKEND_URL=https://your-backend.onrender.com

# Cloudinary (required for media uploads) — Dashboard > Settings > Account
CLOUDINARY_CLOUD_NAME=your-cloud-name

# ToyyibPay (optional — payment integration)
TOYYIBPAY_USER_SECRET_KEY=your_secret_key_here
TOYYIBPAY_CATEGORY_CODE=your_category_code_here
